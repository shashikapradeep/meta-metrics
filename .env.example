# Meta App credentials — from https://developers.facebook.com/apps/
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# Instagram Login credentials (from Instagram product setup). If omitted,
# the app falls back to META_APP_ID / META_APP_SECRET.
# INSTAGRAM_APP_ID=your_instagram_login_app_id
# INSTAGRAM_APP_SECRET=your_instagram_login_app_secret

# Optional: scope override for Instagram Login flow.
# INSTAGRAM_OAUTH_SCOPES=instagram_business_basic,instagram_business_manage_insights
# Optional authorize endpoint override:
# INSTAGRAM_OAUTH_AUTHORIZE_URL=https://api.instagram.com/oauth/authorize

# Must be added as a Valid OAuth Redirect URI under:
#   App Dashboard → Instagram → API setup with Instagram login → Valid OAuth Redirect URIs
# For local dev use: http://localhost:3000/auth/callback
META_REDIRECT_URI=http://localhost:3000/auth/callback

# Meta Ads OAuth callback (for ad-account authorization)
META_ADS_REDIRECT_URI=http://localhost:3000/connections/meta-ads/callback

# Optional Graph version override (defaults to v23.0)
# META_GRAPH_BASE=https://graph.facebook.com/v23.0

PORT=3000

# ── TikTok ───────────────────────────────────────────────────────────────────
# TikTok app credentials — from https://developers.tiktok.com/
# The same client_key / client_secret are used for both Login Kit (Content API)
# and TikTok for Business (Ads API).
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# TikTok for Business (Marketing API) numeric app ID.
# Found in TikTok Developer Portal → your app → Basic Info → "App ID" (a numeric string, e.g. "7123456789012345678").
# This is DIFFERENT from client_key — the Marketing API auth URL requires this numeric value.
TIKTOK_APP_ID=your_numeric_tiktok_app_id

# TikTok Login Kit OAuth callback (Content API / organic metrics).
# Must be registered under your TikTok app → Login Kit → Redirect URI allowlist.
# For local dev: http://localhost:3000/tiktok/auth/callback
TIKTOK_REDIRECT_URI=http://localhost:3000/tiktok/auth/callback

# TikTok for Business OAuth callback (Ads API / Spark Ads paid metrics).
# Must be registered under your TikTok app → TikTok for Business → Redirect URI allowlist.
# For local dev: http://localhost:3000/tiktok/connections/ads/callback
TIKTOK_ADS_REDIRECT_URI=http://localhost:3000/tiktok/connections/ads/callback

# Optional: scope override for TikTok Login Kit.
# TIKTOK_SCOPES=user.info.basic,video.list

# Optional: Content API base URL override (defaults to https://open.tiktokapis.com/v2).
# TIKTOK_CONTENT_BASE=https://open.tiktokapis.com/v2

# Optional: Business API base URL override (defaults to https://business-api.tiktok.com/open_api/v1.3).
# TIKTOK_ADS_BASE=https://business-api.tiktok.com/open_api/v1.3

# ── YouTube / Google ──────────────────────────────────────────────────────────
# Google OAuth app credentials — from https://console.cloud.google.com/
# Enable: YouTube Data API v3, YouTube Analytics API, Google Ads API.
# The same client_id/secret covers both YouTube OAuth flows.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# YouTube (organic) OAuth callback.
# Must be added to Authorized redirect URIs in Google Cloud Console.
# For local dev: http://localhost:3000/youtube/auth/callback
YOUTUBE_REDIRECT_URI=http://localhost:3000/youtube/auth/callback

# Google Ads OAuth callback (separate scope: adwords).
# For local dev: http://localhost:3000/youtube/connections/ads/callback
GOOGLE_ADS_REDIRECT_URI=http://localhost:3000/youtube/connections/ads/callback

# Required for every Google Ads API call. Apply at:
#   https://developers.google.com/google-ads/api/docs/first-call/dev-token
# Approval takes 5–14 business days. Organic YouTube metrics work without this.
GOOGLE_ADS_DEVELOPER_TOKEN=your_22_char_developer_token

# Required only when calling as a Manager (MCC) account.
# Use the plain 10-digit ID (no hyphens).
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# Optional: Google Ads API version override (defaults to v18).
# GOOGLE_ADS_BASE=https://googleads.googleapis.com/v18
