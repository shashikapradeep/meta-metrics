# Meta App credentials — from https://developers.facebook.com/apps/
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# Instagram Login credentials (from Instagram product setup). If omitted,
# the app falls back to META_APP_ID / META_APP_SECRET.
# INSTAGRAM_APP_ID=your_instagram_login_app_id
# INSTAGRAM_APP_SECRET=your_instagram_login_app_secret

# Optional: scope override for Instagram Login flow.
# INSTAGRAM_OAUTH_SCOPES=instagram_business_basic,instagram_business_manage_insights
# Optional authorize endpoint override:
# INSTAGRAM_OAUTH_AUTHORIZE_URL=https://api.instagram.com/oauth/authorize

# Must be added as a Valid OAuth Redirect URI under:
#   App Dashboard → Instagram → API setup with Instagram login → Valid OAuth Redirect URIs
# For local dev use: http://localhost:3000/auth/callback
META_REDIRECT_URI=http://localhost:3000/auth/callback

# Meta Ads OAuth callback (for ad-account authorization)
META_ADS_REDIRECT_URI=http://localhost:3000/connections/meta-ads/callback

# Optional Graph version override (defaults to v23.0)
# META_GRAPH_BASE=https://graph.facebook.com/v23.0

PORT=3000
